<ul role="list" class="representations-calendar width-body fonts-info v--size-icon:1.5em {{ parentClass }}">
    {% set prevYear = null %}
    {% for project in projects %}
        {% set year = project.start_date | formatDate("YYYY") %}
        {% if prevYear != year %}
            <li class="year-divider h3 font-bold" role="presentation">
                <h3 class=" font-size-[--step-6]">{{ year }}</h3>
            </li>
            {% set prevYear = year %}
        {% endif %}
        {% set spectaclePage = null %}
        {% if showSpectacle %}
            {% for p in collections.plays %}
                {% if (p.data.orfeoId == project.spectacle.pk) or (p.page.fileSlug == project.spectacle.name | slugify) %}
                    {% set spectaclePage = p %}
                {% endif %}
            {% endfor %}
        {% endif %}
        <li class="representation">
            <details class="width-body">
                <summary class="button px-card">
                    <span class="dates font-bold">
                        {% if project.sameDay %}
                            <time datetime="{{ project.start_date }}">{{ project.start_date | formatDate("D MMM") }}</time>
                        {% else %}
                            {% set startFmt = "D" if project.sameMonth else "D MMM" %}
                            <time datetime="{{ project.start_date }}">{{ project.start_date | formatDate(startFmt) }}</time>-<time datetime="{{ project.end_date }}">{{ project.end_date | formatDate("D MMM") }}</time>
                        {% endif %}
                    </span>
                    <span class="times small bg-transparent">{{ project.perfTimes | join(", ") }}</span>
                    {% if showSpectacle %}
                        <span class="spectacle bg-transparent">
                            {% if spectaclePage %}
                                {% link url=spectaclePage.page.fileSlug, type="internal", collection="plays", class="uppercase no-underline small" %}{% endlink %}
                            {% else %}
                                {{ project.spectacle.name }}
                            {% endif %}
                        </span>
                    {% endif %}
                    <span class="audience small flow space:0">
                        {% if project.hasSchool %}
                            <span class="">{% icon "tablerOutline:backpack" %}Repr. scolaire</span>
                        {% endif %}
                        {% if project.hasPublic %}
                            <span class="">{% icon "tablerOutline:users" %}Tout public</span>
                        {% endif %}
                    </span>
                    <span class="venue small cluster bg-transparent">
                        {% if project.venueUrl %}
                            <a href="{{ project.venueUrl }}" target="_blank" rel="noopener" class="">{% icon "tablerOutline:external-link" %}{{ project.venue_data.name }}</a>
                        {% else %}
                            <span class="">{{ project.venue_data.name }}</span>
                        {% endif %}
                        {% if project.mapsUrl %}
                            <a href="{{ project.mapsUrl }}" target="_blank" rel="noopener" class="">{% icon "tablerOutline:map-pin" %}{{ project.venue_data.city }}</a>
                        {% else %}
                            <span class="">{% icon "tablerOutline:map-pin" %}{{ project.venue_data.city }}</span>
                        {% endif %}
                    </span>
                </summary>
                <div class="representation-details p-card">
                    <dl
                        class="flow">
                        {# <dt>Public</dt>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <dd class="audience">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {% if project.hasSchool %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <span class="">{% icon "tablerOutline:backpack" %}Repr. scolaire</span>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {% endif %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {% if project.hasPublic %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <span class="">{% icon "tablerOutline:users" %}Tout public</span>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {% endif %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </dd> #}
                        {% if project.performances.length %}
                            <div>
                                <dt class="h4">Séances</dt>
                                <dd class="performances">
                                    <ul>
                                        {% for perf in project.performances %}
                                            <li>
                                                <time datetime="{{ perf.start_datetime }}">{{ perf.start_datetime | formatDate("D MMM HH[h]mm") }}</time>
                                                —
                                                {% if perf.audience === "school" %}
                                                    <span class="">{% icon "tablerOutline:backpack" %}Repr. scolaire</span>
                                                {% else %}
                                                    <span class="">{% icon "tablerOutline:users" %}Tout public</span>
                                                {% endif %}
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </dd>
                            </div>
                        {% endif %}
                        {% if project.venue_data.address1 or project.venue_data.zipcode %}
                            <div>
                                <dt class="h4">Adresse</dt>
                                <dd class="venue-address">
                                    {% if project.mapsUrl %}
                                        <a href="{{ project.mapsUrl }}" target="_blank" rel="noopener">
                                        {% endif %}
                                        {% if project.venue_data.address1 %}
                                            {{ project.venue_data.address1 }},
                                        {% endif %}
                                        {% if project.venue_data.zipcode %}
                                            {{ project.venue_data.zipcode }}
                                        {% endif %}
                                        {{ project.venue_data.city }}
                                        {% if project.mapsUrl %}
                                        </a>
                                    {% endif %}
                                </dd>
                            </div>
                        {% endif %}
                        {% if project.organizer_contact_infos.length %}
                            <div>
                                <dt class="h4">Contact organisateur</dt>
                                <dd class="organizer-contact">
                                    <ul>
                                        {% for contact in project.organizer_contact_infos %}
                                            <li>{{ contact.value }}
                                                {% if contact.label %}
                                                    ({{ contact.label }}){% endif %}
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </dd>
                            {% endif %}
                        </dl>
                    </div>
                </details>
            </li>
        {% else %}
            <li>Aucune date pour le moment.</li>
        {% endfor %}
    </ul>
    <style>
        .representations-calendar .icon {
            vertical-align: -0.2em;
            stroke-width: 2px;
        }
        /* hide default marker */
        .representations-calendar .representation details > summary::-webkit-details-marker {
            display: none;
        }
        .representations-calendar .representation summary {
            border: none;
            border-radius: 0;
            padding-block: var(--step--4);
            border-top: 1px solid var(--read);
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 4fr;
            align-items: center;
            & .dates {}
            & .times {}
            & .spectacle {}
            & .audience {}
            & .venue {}
        }
    </style>
    {% if showSpectacle %}
        <style>
            .representations-calendar .representation summary {
                grid-template-columns: 1fr 1fr 1fr 1fr 4fr;
            }
        </style>
    {% endif %}